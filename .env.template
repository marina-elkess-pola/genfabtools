# .env.template - copy to .env and fill with real values
# SECURITY: Do NOT commit your real .env to source control. Add .env to .gitignore.

# Server
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/occupancy_db

# Auth
JWT_SECRET=change_this_to_a_long_random_string

# Frontend URL (used for return URLs)
FRONTEND_URL=http://localhost:3000

# LemonSqueezy (hosted checkout)
# Replace checkout id with the hosted checkout URL from your LemonSqueezy product share dialog
LEMONSQUEEZY_CHECKOUT_URL=https://buy.lemonsqueezy.com/checkout/<checkout-id>
# Webhook signing secret (copy from LemonSqueezy Webhooks settings)
LEMONSQUEEZY_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Optional: API key (only if you decide to use the LemonSqueezy API directly)
LEMONSQUEEZY_API_KEY=sk_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Redirects used by checkout / return flows
PAYMENT_SUCCESS_URL=http://localhost:3000/purchase/verify
PAYMENT_CANCEL_URL=http://localhost:3000/purchase/cancel

# Optional email settings (if backend sends emails)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=you@example.com
EMAIL_PASS=supersecret

# Optional Stripe values (keep if you still have Stripe code in backend)
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Notes:
# - After copying to .env and filling values, restart your backend server so it picks up the new env vars.
# - For local webhook testing with ngrok, set PAYMENT_SUCCESS_URL to your ngrok URL + "/purchase/verify"
#   and add the ngrok webhook URL (https://<ngrok-id>.ngrok.io/webhook) in LemonSqueezy webhooks. Then
#   set LEMONSQUEEZY_WEBHOOK_SECRET to the secret the dashboard shows for that webhook.
# - Keep production secrets in your hosting provider's secret manager (Render/Heroku/Vercel) rather than
#   committing them to the repo.
